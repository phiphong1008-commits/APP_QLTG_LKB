<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFF9C4"> <TextView
        android:id="@+id/tv_diary_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tiêu đề nhật ký"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#333333"/>

        <TextView
            android:id="@+id/tv_diary_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2026-05-31"
            android:textSize="12sp"
            android:textColor="#757575"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_diary_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nội dung nhật ký..."
            android:textSize="14sp"
            android:textColor="#555555"
            android:maxLines="3"
            android:ellipsize="end"/> </LinearLayout>
</androidx.cardview.widget.CardView>