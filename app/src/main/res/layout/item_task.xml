<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_task_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFF59D">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <ImageView
            android:id="@+id/iv_task_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_square_cell"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_agenda"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#424242" />

        <View
            android:id="@+id/vertical_divider"
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_marginStart="8dp"
            android:background="#80000000"
            app:layout_constraintBottom_toBottomOf="@+id/iv_task_icon"
            app:layout_constraintStart_toEndOf="@+id/iv_task_icon"
            app:layout_constraintTop_toTopOf="@+id/iv_task_icon" />

        <CheckBox
            android:id="@+id/cb_task_status"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:buttonTint="#424242"
            app:layout_constraintBottom_toBottomOf="@+id/iv_task_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/iv_task_icon" />

        <TextView
            android:id="@+id/tv_task_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="4dp"
            android:text="Tiêu đề công việc"
            android:textColor="#212121"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/iv_task_icon"
            app:layout_constraintEnd_toStartOf="@+id/cb_task_status"
            app:layout_constraintStart_toEndOf="@+id/vertical_divider"
            app:layout_constraintTop_toTopOf="@+id/iv_task_icon" />

        <View
            android:id="@+id/horizontal_divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:background="#80000000"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/iv_task_icon" />

        <TextView
            android:id="@+id/tv_task_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Mô tả chi tiết công việc sẽ hiển thị ở đây..."
            android:textColor="#424242"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/horizontal_divider" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>